#!/usr/bin/make -f

METAPKG_NAME := $(shell dpkg-parsechangelog -S Source)
METAPKG_VERSION := $(shell . /etc/build.info && echo $$SW_VERSION).0

# Metapkg name without leading "meta-" prefix
METAPKG_NAME_CORE := $(METAPKG_NAME:meta-%=%)

ROOT := debian/$(METAPKG_NAME)
TARGET_DIR := $(ROOT)/usr/local/share/metapackages/$(METAPKG_VERSION)/$(METAPKG_NAME_CORE)

%:
	dh $@

override_dh_gencontrol:
	dh_gencontrol -- -v$(METAPKG_VERSION)

override_dh_auto_install:
	install -d $(TARGET_DIR)
	cp -r files/. $(TARGET_DIR)/

override_dh_usrlocal:
	# Section left empty to allow installing files to /usr/local/
